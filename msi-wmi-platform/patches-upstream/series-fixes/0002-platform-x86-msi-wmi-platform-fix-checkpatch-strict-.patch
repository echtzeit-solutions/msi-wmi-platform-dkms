From 6e7be3cfa49dc5ad933b5a354ea3503d512f45b6 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Florian=20H=C3=A4nel?= <florian.haenel@echtzeit.solutions>
Date: Thu, 2 Jul 2026 20:34:38 +0200
Subject: [PATCH 2/2] platform/x86: msi-wmi-platform: clean up wrapped-argument formatting

Cosmetic only, no functional change: align wrapped-argument continuation
lines to the open parenthesis, pull first arguments up so lines do not end
with '(', and drop a few stray blank lines.

Signed-off-by: Florian Hänel <florian.haenel@echtzeit.solutions>
Assisted-by: Claude:claude-opus-4-8
---
 drivers/platform/x86/msi-wmi-platform.c | 72 +++++++++++--------------
 1 file changed, 32 insertions(+), 40 deletions(-)

diff --git a/drivers/platform/x86/msi-wmi-platform.c b/drivers/platform/x86/msi-wmi-platform.c
index 4158376..1277fc0 100644
--- a/drivers/platform/x86/msi-wmi-platform.c
+++ b/drivers/platform/x86/msi-wmi-platform.c
@@ -233,6 +233,7 @@ static struct msi_wmi_platform_quirk quirk_gen1 = {
 	.pl1_max = 43,
 	.pl2_max = 45
 };
+
 static struct msi_wmi_platform_quirk quirk_gen2 = {
 	.shift_mode = true,
 	.charge_threshold = true,
@@ -287,8 +288,8 @@ static int msi_wmi_platform_parse_buffer(union acpi_object *obj, u8 *output, siz
 }
 
 static int msi_wmi_platform_query_unlocked(struct msi_wmi_platform_data *data,
-				  enum msi_wmi_platform_method method, u8 *buffer,
-				  size_t length)
+					   enum msi_wmi_platform_method method, u8 *buffer,
+					   size_t length)
 {
 	struct acpi_buffer out = { ACPI_ALLOCATE_BUFFER, NULL };
 	struct acpi_buffer in = {
@@ -524,10 +525,9 @@ static int msi_wmi_platform_curves_save(struct msi_wmi_platform_data *data)
 
 	data->factory_curves.cpu_fan_table[0] =
 		MSI_PLATFORM_FAN_SUBFEATURE_CPU_FAN_TABLE;
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_GET_FAN,
-		data->factory_curves.cpu_fan_table,
-		sizeof(data->factory_curves.cpu_fan_table));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_GET_FAN,
+					      data->factory_curves.cpu_fan_table,
+					      sizeof(data->factory_curves.cpu_fan_table));
 	if (ret < 0)
 		return ret;
 	data->factory_curves.cpu_fan_table[0] =
@@ -535,10 +535,9 @@ static int msi_wmi_platform_curves_save(struct msi_wmi_platform_data *data)
 
 	data->factory_curves.gpu_fan_table[0] =
 		MSI_PLATFORM_FAN_SUBFEATURE_GPU_FAN_TABLE;
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_GET_FAN,
-		data->factory_curves.gpu_fan_table,
-		sizeof(data->factory_curves.gpu_fan_table));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_GET_FAN,
+					      data->factory_curves.gpu_fan_table,
+					      sizeof(data->factory_curves.gpu_fan_table));
 	if (ret < 0)
 		return ret;
 	data->factory_curves.gpu_fan_table[0] =
@@ -546,10 +545,9 @@ static int msi_wmi_platform_curves_save(struct msi_wmi_platform_data *data)
 
 	data->factory_curves.cpu_temp_table[0] =
 		MSI_PLATFORM_FAN_SUBFEATURE_CPU_TEMP_TABLE;
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_GET_TEMPERATURE,
-		data->factory_curves.cpu_temp_table,
-		sizeof(data->factory_curves.cpu_temp_table));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_GET_TEMPERATURE,
+					      data->factory_curves.cpu_temp_table,
+					      sizeof(data->factory_curves.cpu_temp_table));
 	if (ret < 0)
 		return ret;
 	data->factory_curves.cpu_temp_table[0] =
@@ -557,10 +555,9 @@ static int msi_wmi_platform_curves_save(struct msi_wmi_platform_data *data)
 
 	data->factory_curves.gpu_temp_table[0] =
 		MSI_PLATFORM_FAN_SUBFEATURE_GPU_TEMP_TABLE;
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_GET_TEMPERATURE,
-		data->factory_curves.gpu_temp_table,
-		sizeof(data->factory_curves.gpu_temp_table));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_GET_TEMPERATURE,
+					      data->factory_curves.gpu_temp_table,
+					      sizeof(data->factory_curves.gpu_temp_table));
 	if (ret < 0)
 		return ret;
 	data->factory_curves.gpu_temp_table[0] =
@@ -590,22 +587,21 @@ static int msi_wmi_platform_curves_load(struct msi_wmi_platform_data *data)
 
 	memcpy(buffer, data->factory_curves.cpu_temp_table,
 	       sizeof(data->factory_curves.cpu_temp_table));
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_SET_TEMPERATURE, buffer, sizeof(buffer));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_SET_TEMPERATURE,
+					      buffer, sizeof(buffer));
 	if (ret < 0)
 		return ret;
 
 	memcpy(buffer, data->factory_curves.gpu_temp_table,
 	       sizeof(data->factory_curves.gpu_temp_table));
-	ret = msi_wmi_platform_query_unlocked(
-		data, MSI_PLATFORM_SET_TEMPERATURE, buffer, sizeof(buffer));
+	ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_SET_TEMPERATURE,
+					      buffer, sizeof(buffer));
 	if (ret < 0)
 		return ret;
 
 	return 0;
 }
 
-
 static umode_t msi_wmi_platform_is_visible(const void *drvdata, enum hwmon_sensor_types type,
 					   u32 attr, int channel)
 {
@@ -682,9 +678,8 @@ static int msi_wmi_platform_write(struct device *dev, enum hwmon_sensor_types ty
 			guard(mutex)(&data->wmi_lock);
 
 			buffer[0] = MSI_PLATFORM_AP_SUBFEATURE_FAN_MODE;
-			ret = msi_wmi_platform_query_unlocked(
-				data, MSI_PLATFORM_GET_AP, buffer,
-				sizeof(buffer));
+			ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_GET_AP,
+							      buffer, sizeof(buffer));
 			if (ret < 0)
 				return ret;
 
@@ -702,9 +697,8 @@ static int msi_wmi_platform_write(struct device *dev, enum hwmon_sensor_types ty
 				return -EINVAL;
 			}
 
-			ret = msi_wmi_platform_query_unlocked(
-				data, MSI_PLATFORM_SET_AP, buffer,
-				sizeof(buffer));
+			ret = msi_wmi_platform_query_unlocked(data, MSI_PLATFORM_SET_AP,
+							      buffer, sizeof(buffer));
 			if (ret < 0)
 				return ret;
 
@@ -933,8 +927,8 @@ static struct kobj_attribute fw_attr_display_name_language_code =
 	__ATTR_RO(display_name_language_code);
 
 static ssize_t scalar_increment_show(struct kobject *kobj,
-					       struct kobj_attribute *attr,
-					       char *buf)
+				     struct kobj_attribute *attr,
+				     char *buf)
 {
 	return sysfs_emit(buf, "1\n");
 }
@@ -943,7 +937,7 @@ static struct kobj_attribute fw_attr_scalar_increment =
 	__ATTR_RO(scalar_increment);
 
 static ssize_t pending_reboot_show(struct kobject *kobj,
-				     struct kobj_attribute *attr, char *buf)
+				   struct kobj_attribute *attr, char *buf)
 {
 	return sysfs_emit(buf, "0\n");
 }
@@ -1101,7 +1095,7 @@ static int msi_wmi_fw_attrs_init(struct msi_wmi_platform_data *data)
 	int err;
 
 	data->fw_attrs_dev = device_create(&firmware_attributes_class, NULL, MKDEV(0, 0),
-						 NULL, "%s", DRIVER_NAME);
+					   NULL, "%s", DRIVER_NAME);
 	if (IS_ERR(data->fw_attrs_dev))
 		return PTR_ERR(data->fw_attrs_dev);
 
@@ -1130,9 +1124,9 @@ static int msi_wmi_fw_attrs_init(struct msi_wmi_platform_data *data)
 
 	if (data->quirks->pl1_max) {
 		err = msi_fw_attr_init(data, MSI_ATTR_PPT_PL1_SPL,
-					&fw_attr_type_int, data->quirks->pl_min,
-					data->quirks->pl1_max, &data_get_value,
-					&data_set_value);
+				       &fw_attr_type_int, data->quirks->pl_min,
+				       data->quirks->pl1_max, &data_get_value,
+				       &data_set_value);
 		if (err)
 			return err;
 	}
@@ -1425,9 +1419,8 @@ static int msi_wmi_platform_profile_setup(struct msi_wmi_platform_data *data)
 	if (!data->quirks->shift_mode)
 		return 0;
 
-	data->ppdev = devm_platform_profile_register(
-		&data->wdev->dev, "msi-wmi-platform", data,
-		&msi_wmi_platform_profile_ops);
+	data->ppdev = devm_platform_profile_register(&data->wdev->dev, "msi-wmi-platform", data,
+						     &msi_wmi_platform_profile_ops);
 
 	return PTR_ERR_OR_ZERO(data->ppdev);
 }
@@ -1556,7 +1549,6 @@ static void __exit msi_wmi_platform_module_exit(void)
 module_init(msi_wmi_platform_module_init);
 module_exit(msi_wmi_platform_module_exit);
 
-
 MODULE_AUTHOR("Armin Wolf <W_Armin@gmx.de>");
 MODULE_DESCRIPTION("MSI WMI platform features");
 MODULE_LICENSE("GPL");

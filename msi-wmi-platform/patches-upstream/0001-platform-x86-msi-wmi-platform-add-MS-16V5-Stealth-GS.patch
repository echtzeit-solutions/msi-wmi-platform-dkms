From a86aaa7baa8b8718ef10149c024372f584f85f01 Mon Sep 17 00:00:00 2001
From: Florian Hänel <florian.haenel@echtzeit.solutions>
Date: Wed, 1 Jul 2026 19:13:38 +0200
Subject: [PATCH 1/3] platform/x86: msi-wmi-platform: add MS-16V5 (Stealth GS66
 12Ux) quirk

Add a quirk for the MSI MS-16V5 board family (Stealth GS66 12UHS and
siblings, EC firmware 16V5EMS1.*).

Verified on a GS66 12UHS (EC 16V5EMS1.108): platform_profile maps to EC
shift-mode (0xD2: eco/comfort/turbo), battery charge threshold to EC 0xD7
(value | BIT(7); start = end - 10), and the pwm1/pwm2 fan curves control
the CPU and GPU fans respectively. TDP (PLx) is left unset as no validated
PL1/PL2 limits are known for this board yet.

Signed-off-by: Florian Hänel <florian.haenel@echtzeit.solutions>
Assisted-by: Claude:claude-opus-4-8
---
 drivers/platform/x86/msi-wmi-platform.c | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/drivers/platform/x86/msi-wmi-platform.c b/drivers/platform/x86/msi-wmi-platform.c
index dfb65ac..5b4d406 100644
--- a/drivers/platform/x86/msi-wmi-platform.c
+++ b/drivers/platform/x86/msi-wmi-platform.c
@@ -242,8 +242,27 @@ static struct msi_wmi_platform_quirk quirk_gen2 = {
 	.pl1_max = 30,
 	.pl2_max = 37
 };
+/*
+ * MSI Stealth GS66 12UHS and MS-16V5 siblings (EC 16V5EMS1.*).
+ * shift-mode/charge/dual-fan/curve-restore verified on 12UHS (EC 16V5EMS1.108).
+ * TDP (PLx) left unset: no validated PL1/PL2 limits for this board yet.
+ */
+static struct msi_wmi_platform_quirk quirk_16v5 = {
+	.shift_mode = true,
+	.charge_threshold = true,
+	.dual_fans = true,
+	.restore_curves = true,
+};
 
 static const struct dmi_system_id msi_quirks[] = {
+	{
+		.ident = "MSI Stealth GS66 12Ux (MS-16V5)",
+		.matches = {
+			DMI_MATCH(DMI_SYS_VENDOR, "Micro-Star International Co., Ltd."),
+			DMI_MATCH(DMI_BOARD_NAME, "MS-16V5"),
+		},
+		.driver_data = &quirk_16v5,
+	},
 	{
 		.ident = "MSI Claw (gen 1)",
 		.matches = {
-- 
